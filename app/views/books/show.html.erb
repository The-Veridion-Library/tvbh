<div class="max-w-2xl">
  <%# ── Status Banner ──────────────────────────────────────────────────────── %>
  <% if @book.user == current_user %>
    <% if @book.pending? %>
      <div class="bg-amber-50 border border-amber-200 rounded-xl px-5 py-4 mb-5 flex gap-3 items-start">
        <span class="text-xl mt-0.5">⏳</span>
        <div>
          <p class="font-semibold text-amber-800">Under Review</p>
          <p class="text-amber-700 text-sm mt-0.5">Your submission is being reviewed by our team. We'll update this page once it's approved — usually within 24 hours.</p>
        </div>
      </div>
    <% elsif @book.rejected? %>
      <div class="bg-red-50 border border-red-200 rounded-xl px-5 py-4 mb-5 flex gap-3 items-start">
        <span class="text-xl mt-0.5">❌</span>
        <div>
          <p class="font-semibold text-red-800">Submission Not Approved</p>
          <% if @book.rejection_reason.present? %>
            <p class="text-red-700 text-sm mt-1"><strong>Reason:</strong> <%= @book.rejection_reason %></p>
          <% end %>
          <p class="text-red-600 text-sm mt-2">Questions? Reach out to us.</p>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="card mb-6">
    <%# ── Cover photos ──────────────────────────────────────────────────────── %>
    <% if @book.front_cover.present? || @book.back_cover.present? %>
      <div class="flex gap-3 mb-5">
        <% if @book.front_cover.present? %>
          <div class="flex-1">
            <p class="text-xs text-slate-400 mb-1 font-medium uppercase tracking-wide">Front</p>
            <img src="<%= @book.front_cover %>" alt="Front cover" class="w-full h-52 object-cover rounded-xl">
          </div>
        <% end %>
        <% if @book.back_cover.present? %>
          <div class="flex-1">
            <p class="text-xs text-slate-400 mb-1 font-medium uppercase tracking-wide">Back</p>
            <img src="<%= @book.back_cover %>" alt="Back cover" class="w-full h-52 object-cover rounded-xl">
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="w-full h-36 bg-slate-100 rounded-xl mb-5 flex items-center justify-center text-5xl">📖</div>
    <% end %>

    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-slate-900"><%= @book.title %></h1>
        <p class="text-slate-500 mt-1">by <span class="font-medium text-slate-700"><%= @book.author %></span></p>
      </div>
      <div class="flex flex-col items-end gap-1 flex-shrink-0">
        <span class="badge-pill <%= @book.status == 'hidden' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700' %>">
          <%= @book.status.capitalize %>
        </span>
        <span class="badge-pill <%= @book.pending? ? 'bg-amber-50 text-amber-600' : @book.approved? ? 'bg-emerald-50 text-emerald-600' : 'bg-red-50 text-red-600' %>">
          <%= @book.submission_status.humanize %>
        </span>
      </div>
    </div>

    <div class="mt-4 pt-4 border-t border-slate-100 grid grid-cols-2 gap-4 text-sm">
      <% if @book.isbn.present? %>
        <div><span class="text-slate-500">ISBN</span><p class="font-medium text-slate-800"><%= @book.isbn %></p></div>
      <% end %>
      <% if @book.book_condition.present? %>
        <div><span class="text-slate-500">Condition</span><p class="font-medium text-slate-800"><%= @book.condition_label %></p></div>
      <% end %>
      <div><span class="text-slate-500">Submitted by</span><p class="font-medium"><%= link_to @book.user.username, profile_path(@book.user.username), class: "text-indigo-600 hover:underline" %></p></div>
      <% if @book.preferred_location.present? %>
        <div><span class="text-slate-500">Preferred location</span><p class="font-medium text-slate-800"><%= @book.preferred_location.name %></p></div>
      <% end %>
    </div>

    <% if @book.submission_notes.present? && (@book.user == current_user || current_user.admin?) %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <span class="text-slate-500 text-sm">Submission notes</span>
        <p class="text-slate-700 text-sm mt-1"><%= @book.submission_notes %></p>
      </div>
    <% end %>

    <% unless @book.approved? || @book.user != current_user %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <%= button_to "Report this book", report_book_path(@book), method: :post, class: "text-slate-400 hover:text-red-500 text-xs bg-transparent border-0 p-0 cursor-pointer" %>
      </div>
    <% end %>
  </div>

  <%# ── QR Label (approved + owner only) ───────────────────────────────────── %>
  <% if @book.approved? && @book.user == current_user %>
    <% if @qr_svg && @label %>
      <div class="card print:shadow-none mb-5">
        <h2 class="text-lg font-semibold text-slate-800 mb-1">🏷 Your QR Label</h2>
        <p class="text-slate-500 text-sm mb-4">Print this and stick it inside the front cover before you hide the book at <strong><%= @label.location.name %></strong>.</p>
        <div class="flex justify-center p-6 bg-white border border-slate-200 rounded-xl">
          <%= raw @qr_svg %>
        </div>
        <div class="mt-4">
          <button onclick="window.print()" class="btn-secondary text-sm">🖨 Print Label</button>
        </div>
      </div>
    <% else %>
      <div class="card bg-emerald-50 border border-emerald-100 mb-5">
        <p class="text-emerald-700 font-semibold">✅ Approved!</p>
        <p class="text-emerald-600 text-sm mt-1">Your book was approved but no label has been assigned yet. An admin will set up your label shortly — check back soon.</p>
      </div>
    <% end %>
  <% end %>

  <div class="mt-2">
    <%= link_to "← Submit another book", new_book_path, class: "text-slate-500 hover:text-slate-700 text-sm" %>
  </div>
</div>
