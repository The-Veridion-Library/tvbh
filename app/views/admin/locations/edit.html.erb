<div class="flex items-center gap-3 mb-6">
  <%= link_to "← #{@location.name}", admin_location_path(@location), class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>
<div class="max-w-xl">
  <h1 class="page-title">Edit Location</h1>
  <div class="card mt-4">
    <%= form_with model: [:admin, @location] do |f| %>
      <% if @location.errors.any? %>
        <div class="error-box"><% @location.errors.full_messages.each do |m| %><p>• <%= m %></p><% end %></div>
      <% end %>
      <div class="form-group"><%= f.label :name, class: "form-label" %><%= f.text_field :name, class: "form-input" %></div>
      <div class="form-group">
        <%= f.label :location_type, "Type", class: "form-label" %>
        <%= f.select :location_type, [["Library","library"],["Book Store","bookstore"],["Café","cafe"],["Park","park"],["Other","other"]], {}, { class: "form-input" } %>
      </div>
      <div class="form-group"><%= f.label :website, class: "form-label" %><%= f.text_field :website, class: "form-input" %></div>
      <div class="form-group"><%= f.label :address_line_1, class: "form-label" %><%= f.text_field :address_line_1, class: "form-input" %></div>
      <div class="form-group"><%= f.label :address_line_2, class: "form-label" %><%= f.text_field :address_line_2, class: "form-input" %></div>
      <div class="grid grid-cols-2 gap-4">
        <div class="form-group"><%= f.label :city, class: "form-label" %><%= f.text_field :city, class: "form-input" %></div>
        <div class="form-group"><%= f.label :state, class: "form-label" %><%= f.text_field :state, class: "form-input" %></div>
      </div>
      <div class="form-group"><%= f.label :zip_code, "ZIP", class: "form-label" %><%= f.text_field :zip_code, class: "form-input" %></div>
      <div class="grid grid-cols-2 gap-4">
        <div class="form-group"><%= f.label :latitude, class: "form-label" %><%= f.number_field :latitude, step: :any, class: "form-input" %></div>
        <div class="form-group"><%= f.label :longitude, class: "form-label" %><%= f.number_field :longitude, step: :any, class: "form-input" %></div>
      </div>
      <div class="form-group"><%= f.label :contact_name, "Contact Hint", class: "form-label" %><%= f.text_field :contact_name, class: "form-input" %></div>
      <div class="form-group"><%= f.label :nomination_notes, "Notes", class: "form-label" %><%= f.text_area :nomination_notes, rows: 3, class: "form-input" %></div>
      <div class="form-group">
        <%= f.label :nomination_status, "Status", class: "form-label" %>
        <%= f.select :nomination_status, [["⏳ Nominated","nominated"],["🔍 Under Review","under_review"],["✅ Partner","partner"],["❌ Declined","declined"]], {}, { class: "form-input" } %>
      </div>
      <div class="flex gap-3 mt-6">
        <%= f.submit "Save", class: "btn-primary" %>
        <%= link_to "Cancel", admin_location_path(@location), class: "btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
