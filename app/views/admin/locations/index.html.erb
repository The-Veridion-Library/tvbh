<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">📍 Locations</h1>
    <% if @pending_count > 0 %>
      <p class="text-amber-600 text-sm font-medium mt-0.5">⏳ <%= @pending_count %> nomination<%= @pending_count == 1 ? '' : 's' %> pending</p>
    <% end %>
  </div>
  <div class="flex gap-2 flex-wrap">
    <%= link_to "All", admin_locations_path, class: "btn-secondary text-sm py-1.5 #{params[:status].blank? ? 'bg-slate-200' : ''}" %>
    <%= link_to "⏳ Pending#{@pending_count > 0 ? " (#{@pending_count})" : ''}", admin_locations_path(status: 'nominated'),
        class: "btn-secondary text-sm py-1.5 #{params[:status] == 'nominated' ? 'bg-amber-100 border-amber-300 text-amber-700' : ''}" %>
    <%= link_to "🔍 Under Review", admin_locations_path(status: 'under_review'),
        class: "btn-secondary text-sm py-1.5 #{params[:status] == 'under_review' ? 'bg-blue-100 border-blue-300 text-blue-700' : ''}" %>
    <%= link_to "✅ Partners", admin_locations_path(status: 'partner'),
        class: "btn-secondary text-sm py-1.5 #{params[:status] == 'partner' ? 'bg-emerald-100 border-emerald-300 text-emerald-700' : ''}" %>
    <%= link_to "❌ Declined", admin_locations_path(status: 'declined'),
        class: "btn-secondary text-sm py-1.5 #{params[:status] == 'declined' ? 'bg-slate-200' : ''}" %>
  </div>
</div>

<div class="card p-0 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-100">
      <tr>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Venue</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Type</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">City, State</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Nominated by</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Status</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @locations.each do |location| %>
        <tr class="hover:bg-slate-50 <%= 'bg-amber-50' if location.nominated? %>">
          <td class="px-5 py-3">
            <p class="font-medium text-slate-800"><%= location.name %></p>
            <% if location.website.present? %>
              <a href="<%= location.website %>" target="_blank" class="text-indigo-500 text-xs hover:underline truncate block max-w-[140px]"><%= location.website %></a>
            <% end %>
          </td>
          <td class="px-5 py-3">
            <span class="badge-pill bg-slate-100 text-slate-600"><%= location.location_type %></span>
          </td>
          <td class="px-5 py-3 text-slate-600"><%= [location.city, location.state].compact.join(', ') %></td>
          <td class="px-5 py-3 text-slate-500">
            <% if location.nominator %>
              <%= link_to location.nominator.username, admin_user_path(location.nominator), class: "hover:text-indigo-600" %>
            <% else %>
              <span class="text-slate-300">—</span>
            <% end %>
          </td>
          <td class="px-5 py-3">
            <span class="badge-pill <%= case location.nomination_status
              when 'nominated'    then 'bg-amber-100 text-amber-700'
              when 'under_review' then 'bg-blue-100 text-blue-700'
              when 'partner'      then 'bg-emerald-100 text-emerald-700'
              when 'declined'     then 'bg-slate-100 text-slate-500'
              end %>">
              <%= case location.nomination_status
                when 'nominated'    then '⏳ Nominated'
                when 'under_review' then '🔍 Under Review'
                when 'partner'      then '✅ Partner'
                when 'declined'     then '❌ Declined'
                end %>
            </span>
          </td>
          <td class="px-5 py-3 text-right">
            <%= link_to "Review →", admin_location_path(location), class: "text-indigo-600 hover:underline font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
