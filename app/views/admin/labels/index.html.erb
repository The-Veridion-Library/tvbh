<div class="flex items-center justify-between mb-6">
  <h1 class="page-title">🏷 Labels</h1>
  <div class="flex gap-2">
    <%= link_to "All", admin_labels_path, class: "btn-secondary text-sm py-1.5 #{params[:status].blank? ? 'bg-slate-200' : ''}" %>
    <%= link_to "Created", admin_labels_path(status: 'created'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'created' ? 'bg-slate-200' : ''}" %>
    <%= link_to "Printed", admin_labels_path(status: 'printed'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'printed' ? 'bg-slate-200' : ''}" %>
    <%= link_to "Placed", admin_labels_path(status: 'placed'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'placed' ? 'bg-slate-200' : ''}" %>
    <%= link_to "Invalidated", admin_labels_path(status: 'invalidated'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'invalidated' ? 'bg-slate-200' : ''}" %>
  </div>
</div>

<div class="card p-0 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-100">
      <tr>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Book</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Location</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Owner</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Status</th>
        <th class="text-left px-6 py-3 text-slate-500 font-medium">Created</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @labels.each do |label| %>
        <tr class="hover:bg-slate-50">
          <td class="px-6 py-3 font-medium text-slate-800 truncate max-w-[140px]"><%= label.book.title %></td>
          <td class="px-6 py-3 text-slate-600 truncate max-w-[140px]"><%= label.location.name %></td>
          <td class="px-6 py-3 text-slate-500"><%= label.user.username %></td>
          <td class="px-6 py-3">
            <span class="badge-pill <%= label.status == 'placed' ? 'bg-emerald-100 text-emerald-700' : label.status == 'invalidated' ? 'bg-red-100 text-red-700' : label.status == 'printed' ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
              <%= label.status %>
            </span>
          </td>
          <td class="px-6 py-3 text-slate-400"><%= label.created_at.strftime("%b %d") %></td>
          <td class="px-6 py-3 text-right flex gap-2 justify-end">
            <%= link_to "Manage", admin_label_path(label), class: "text-indigo-600 hover:underline" %>
            <%= button_to "Delete", admin_label_path(label), method: :delete, class: "text-red-500 hover:underline bg-transparent border-0 cursor-pointer p-0 text-sm", data: { confirm: "Delete this label?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
