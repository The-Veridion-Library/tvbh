<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="page-title">📚 Books</h1>
    <div class="flex gap-3 mt-1 text-sm">
      <% if @pending_count > 0 %>
        <span class="text-amber-600 font-medium">⏳ <%= @pending_count %> pending review</span>
      <% end %>
      <% if @flagged_count > 0 %>
        <span class="text-red-500 font-medium">🚩 <%= @flagged_count %> flagged</span>
      <% end %>
    </div>
  </div>
  <div class="flex gap-2 flex-wrap">
    <%= link_to "All", admin_books_path, class: "btn-secondary text-sm py-1.5 #{params[:status].blank? && params[:flagged].blank? ? 'bg-slate-200' : ''}" %>
    <%= link_to "⏳ Pending#{@pending_count > 0 ? " (#{@pending_count})" : ''}", admin_books_path(status: 'pending_review'),
        class: "btn-secondary text-sm py-1.5 #{params[:status] == 'pending_review' ? 'bg-amber-100 border-amber-300 text-amber-700' : ''}" %>
    <%= link_to "✅ Approved", admin_books_path(status: 'approved'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'approved' ? 'bg-slate-200' : ''}" %>
    <%= link_to "❌ Rejected", admin_books_path(status: 'rejected'), class: "btn-secondary text-sm py-1.5 #{params[:status] == 'rejected' ? 'bg-slate-200' : ''}" %>
    <%= link_to "🚩 Flagged", admin_books_path(flagged: 'true'), class: "btn-secondary text-sm py-1.5 #{params[:flagged] == 'true' ? 'bg-red-100 border-red-300 text-red-700' : ''}" %>
  </div>
</div>

<div class="card p-0 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-100">
      <tr>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Book</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Submitted by</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Condition</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Status</th>
        <th class="text-left px-5 py-3 text-slate-500 font-medium">Date</th>
        <th class="px-5 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @books.each do |book| %>
        <tr class="hover:bg-slate-50 <%= 'bg-amber-50' if book.pending? %> <%= 'bg-red-50' if book.flagged? %>">
          <td class="px-5 py-3">
            <p class="font-medium text-slate-800 max-w-[160px] truncate">
              <%= book.title %>
              <% if book.flagged? %><span class="ml-1 text-red-500 text-xs">🚩</span><% end %>
            </p>
            <p class="text-slate-400 text-xs"><%= book.author %></p>
          </td>
          <td class="px-5 py-3 text-slate-600">
            <%= link_to book.user.username, admin_user_path(book.user), class: "hover:text-indigo-600" %>
          </td>
          <td class="px-5 py-3 text-slate-500"><%= book.condition_label.presence || '—' %></td>
          <td class="px-5 py-3">
            <span class="badge-pill <%= case book.submission_status
              when 'pending_review' then 'bg-amber-100 text-amber-700'
              when 'approved'       then 'bg-emerald-100 text-emerald-700'
              when 'rejected'       then 'bg-red-100 text-red-700'
              end %>"><%= book.submission_status&.humanize || 'Unknown' %></span>
          </td>
          <td class="px-5 py-3 text-slate-400"><%= book.created_at.strftime("%b %d") %></td>
          <td class="px-5 py-3 text-right">
            <%= link_to "Review →", admin_book_path(book), class: "text-indigo-600 hover:underline font-medium" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
